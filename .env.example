# Copy to .env and fill in values (never commit .env)

# Slack alerting (optional)
TELEMETRY_ALERTING_ENABLED=false
TELEMETRY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TELEMETRY_ALERTING_MIN_SEVERITY=medium
TELEMETRY_ALERTING_COOLDOWN_SECONDS=60

# API security (optional — protects /api/* endpoints)
TELEMETRY_API_KEY=

# Multi-tenant API keys (tenant_id -> key), JSON object
TELEMETRY_TENANT_KEYS={"acme":"acme-secret-key","globex":"globex-secret-key"}

# Kafka replay (reprocess from beginning)
# Set in config: ingestion.kafka.replay_mode: true

# Kafka per-tenant topics (requires tenancy.enabled: true)
# ingestion.kafka.topic_per_tenant: true
# ingestion.kafka.topic_template: telemetry.events.{tenant_id}

# OpenTelemetry (enable in config: opentelemetry.enabled: true)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Logging: set logging.format: json in pipeline.yaml for Loki

# Metrics: VictoriaMetrics (free) replaces Prometheus in Docker on port 8428
# Per-tenant labels: prometheus.per_tenant_labels: true