      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT\n  $__timeGroupAlias(window_start, $__interval),\n  avg(mean) AS vibration\nFROM window_stats\nWHERE $__timeFilter(window_start)\n  AND field = 'vibration'\nGROUP BY 1\nORDER BY 1",
