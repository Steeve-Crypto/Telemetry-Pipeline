    {
      "id": 14,
      "type": "table",
      "title": "Recent Anomalies",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT\n  timestamp,\n  device_id,\n  sensor_type,\n  round(score::numeric, 3) AS score,\n  severity,\n  drift_detected,\n  message\nFROM anomaly_scores\nWHERE is_anomaly = true\nORDER BY timestamp DESC\nLIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
