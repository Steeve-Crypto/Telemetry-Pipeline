    {
      "id": 4,
      "type": "stat",
      "title": "Avg Ingest Latency",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT round(avg(ingest_latency_ms)::numeric, 2) AS latency FROM telemetry_events WHERE timestamp > NOW() - INTERVAL '1 hour'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
