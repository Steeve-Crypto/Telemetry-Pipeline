      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT\n  $__timeGroupAlias(timestamp, $__interval),\n  sensor_type,\n  count(*)::bigint AS events\nFROM telemetry_events\nWHERE $__timeFilter(timestamp)\nGROUP BY 1, 2\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
