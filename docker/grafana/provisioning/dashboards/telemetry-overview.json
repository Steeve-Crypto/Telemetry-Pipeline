    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ingest Latency",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT\n  $__timeGroupAlias(timestamp, $__interval),\n  avg(ingest_latency_ms) AS \"Avg\",\n  percentile_cont(0.95) WITHIN GROUP (ORDER BY ingest_latency_ms) AS \"P95\"\nFROM telemetry_events\nWHERE $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ms"
