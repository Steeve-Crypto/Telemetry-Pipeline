{
  "uid": "telemetry-tenant-metrics",
  "title": "Per-Tenant Metrics",
  "description": "Tenant-scoped pipeline throughput, latency, and anomaly counters (VictoriaMetrics)",
  "tags": ["telemetry", "tenant", "metrics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(telemetry_events_ingested_total, tenant_id)",
        "query": {"query": "label_values(telemetry_events_ingested_total, tenant_id)", "refId": "A"},
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Ingest Rate (/s)",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum(rate(telemetry_events_ingested_total{tenant_id=~\"$tenant\"}[1m]))",
        "legendFormat": "eps",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ops", "decimals": 1}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Valid Events (total)",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum(telemetry_events_valid_total{tenant_id=~\"$tenant\"})",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Anomalies (total)",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}},
      "targets": [{
        "expr": "sum(telemetry_anomalies_detected_total{tenant_id=~\"$tenant\"})",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Throughput (gauge)",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum(telemetry_throughput_eps{tenant_id=~\"$tenant\"})",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingest Rate by Tenant",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (tenant_id) (rate(telemetry_events_ingested_total{tenant_id=~\"$tenant\"}[1m]))",
        "legendFormat": "{{tenant_id}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Anomaly Rate by Tenant",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (tenant_id) (rate(telemetry_anomalies_detected_total{tenant_id=~\"$tenant\"}[5m]))",
        "legendFormat": "{{tenant_id}}",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Processing Latency (ms)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "telemetry_processing_latency_avg_ms{tenant_id=~\"$tenant\"}", "legendFormat": "avg {{tenant_id}}", "refId": "A"},
        {"expr": "telemetry_processing_latency_p95_ms{tenant_id=~\"$tenant\"}", "legendFormat": "p95 {{tenant_id}}", "refId": "B"},
        {"expr": "telemetry_processing_latency_p99_ms{tenant_id=~\"$tenant\"}", "legendFormat": "p99 {{tenant_id}}", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Invalid / Deduped Events",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (tenant_id) (rate(telemetry_events_invalid_total{tenant_id=~\"$tenant\"}[5m]))", "legendFormat": "invalid {{tenant_id}}", "refId": "A"},
        {"expr": "sum by (tenant_id) (rate(telemetry_events_deduped_total{tenant_id=~\"$tenant\"}[5m]))", "legendFormat": "deduped {{tenant_id}}", "refId": "B"}
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Tenant Comparison — Total Events",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 23},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "targets": [{
        "expr": "sum by (tenant_id) (telemetry_events_ingested_total)",
        "legendFormat": "{{tenant_id}}",
        "refId": "A"
      }]
    }
  ]
}